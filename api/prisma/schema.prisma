generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wisata {
  id          Int       @id @default(autoincrement())
  nama        String
  deskripsi   String
  lokasi      String
  latitude    Float?
  longitude   Float?
  jamBuka     String?
  hargaTiket  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  galeri      Galeri[]
  reviews     Review[]
  bookings    Booking[]
}
